{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@venomous-snake/engine": ["packages/engine/src/index.ts"],
      "@venomous-snake/ui": ["packages/ui/src/index.ts"],
      "@venomous-snake/python-runtime": ["packages/python-runtime/src/index.ts"],
      "@venomous-snake/challenge-engine": ["packages/challenge-engine/src/index.ts"],
      "@venomous-snake/challenges": ["packages/challenges/src/index.ts"],
      "@venomous-snake/narrative": ["packages/narrative/src/index.ts"],
      "@venomous-snake/audio": ["packages/audio/src/index.ts"],
      "@venomous-snake/i18n": ["packages/i18n/src/index.ts"],
      "@venomous-snake/save-system": ["packages/save-system/src/index.ts"],
      "@venomous-snake/shared-types": ["packages/shared-types/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "coverage"]
}
